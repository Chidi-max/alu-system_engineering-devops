#!/usr/bin/env bash
# Install and configure HAproxy load balancer (7054 project)

set -e

# Update package list
apt-get update -y

# Install HAproxy
apt-get install -y haproxy

# Enable HAproxy init script (required by checker)
sed -i "s/ENABLED=0/ENABLED=1/" /etc/default/haproxy

# Backup original config
cp /etc/haproxy/haproxy.cfg /etc/haproxy/haproxy.cfg.bak

# Write HAproxy configuration
cat > /etc/haproxy/haproxy.cfg <<EOF

global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend http_front
    bind *:80
    default_backend web_back

backend web_back
    balance roundrobin
    server 7054-web-01 54.86.170.68:80 check
    server 7054-web-02 32.192.238.33:80 check

EOF

# Restart and enable HAproxy
systemctl restart haproxy
systemctl enable haproxy

exit 0
