#!/usr/bin/env bash
# Installs nginx and configures it to send X-Served-By header with hostname

# Install nginx
sudo apt update -y
sudo apt install nginx -y

# Overwrite default config completely (clean + predictable)
sudo tee /etc/nginx/sites-available/default > /dev/null <<EOF
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html;

    server_name _;

    location / {
        try_files \$uri \$uri/ =404;
    }

    add_header X-Served-By \$hostname always;
}
EOF

# Restart nginx
sudo systemctl restart nginx
